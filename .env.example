# SlideCraft 环境变量配置示例
# 复制此文件为 .env，然后填入你的 API Key

# ===========================================
# MiniMax（科技云）
# ===========================================
# MINIMAX_API_KEY=your-minimax-key

# ===========================================
# DeepSeek
# https://platform.deepseek.com/
# ===========================================
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# ===========================================
# OpenAI
# https://platform.openai.com/api-keys
# ===========================================
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ===========================================
# 阿里通义千问（百炼平台）
# https://bailian.console.aliyun.com/
# ===========================================
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# ===========================================
# 腾讯混元
# https://console.cloud.tencent.com/hunyuan
# ===========================================
# TENCENT_SECRET_ID=your-secret-id
# TENCENT_SECRET_KEY=your-secret-key

# ===========================================
# 字节豆包（火山引擎）
# https://console.volcengine.com/ark
# ===========================================
# ARK_API_KEY=xxxxxxxxxxxxxxxx

# ===========================================
# 智谱 GLM
# https://open.bigmodel.cn/
# ===========================================
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxx

# ===========================================
# 百度文心一言
# https://console.bce.baidu.com/
# ===========================================
# ERNIE_API_KEY=xxxxxxxxxxxxxxxx
# ERNIE_SECRET_KEY=xxxxxxxxxxxxxxxx

# ===========================================
# 默认配置（可选）
# ===========================================
# SLIDECRAFT_DEFAULT_MODEL=deepseek-chat
# SLIDECRAFT_PORT=5000
